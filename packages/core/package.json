{
  "name": "@game-claw/core",
  "version": "0.0.1",
  "type": "module",
  "description": "Cryptographic card game engine \u2014 transport, crypto, chip providers, dealer/player nodes",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md",
    "README.zh.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prebuild": "rm -rf dist",
    "test": "vitest run"
  },
  "keywords": [
    "card-game",
    "poker",
    "blackjack",
    "crypto",
    "decentralized",
    "ai-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZZZDAD/game-claw",
    "directory": "packages/core"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "viem": "^2.21.0",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "vitest": "^3.1.0",
    "typescript": "^5.4.0"
  }
}